erDiagram
  ACCOUNT ||--o{ APPLICATION : "submits"
  ACCOUNT ||--o{ NOTIFICATION : "receives"
  ACCOUNT ||--o{ CONTRACT : "holds"
  ACCOUNT ||--o{ STALL : "manages / occupies"
  STALL ||--o{ APPLICATION : "is target of"
  STALL ||--o{ CONTRACT : "covered by"
  APPLICATION ||--o| PAYMENT : "settled by"
  ACCOUNT {
    string id PK
    string firstName
    string lastName
    string email
    string role "renter / contractor / admin"
    string status
  }
  STALL {
    string id PK
    string number
    string zone
    string category
    string status
    string tenantId FK
  }
  APPLICATION {
    string id PK
    string applicantId FK
    string stallId FK
    string status
    string rejectionReason
    int appealCount
  }
  PAYMENT {
    string id PK
    string applicationId FK
    decimal amount
    string status
    date paidAt
  }
  CONTRACT {
    string id PK
    string tenantId FK
    string stallId FK
    date leaseStart
    date leaseEnd
    date deadline
  }
  NOTIFICATION {
    string id PK
    string recipientId FK
    string type
    string message
    bool isRead
  }
