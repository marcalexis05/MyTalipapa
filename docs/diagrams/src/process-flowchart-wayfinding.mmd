flowchart TB
  start(["Start"]):::term
  a1["Open 360 Tour"]:::act
  a2["Search / select destination stall"]:::act
  a3["Compute shortest route<br/>(Dijkstra over aisle/corridor graph)"]:::act
  a4["Show route on panorama + floor map"]:::act
  d1{"Open AR view?"}:::dec
  pan["Follow panorama arrows<br/>(look and walk)"]:::act
  a5["Open AR Finder (live camera)"]:::act
  d2{"Scan QR code?"}:::dec
  qr["Scan QR · recognize stall<br/>· set 'I am here'"]:::act
  a6["Track position<br/>(step detection + compass)"]:::act
  d3{"Arrived at stall?"}:::dec
  a7["Show stall info<br/>(name · products · hours · vendor)"]:::act
  done(["End"]):::term
  start --> a1 --> a2 --> a3 --> a4 --> d1
  d1 -->|"No"| pan
  d1 -->|"Yes"| a5
  pan --> d3
  a5 --> d2
  d2 -->|"Yes"| qr
  d2 -->|"No"| a6
  qr --> a6
  a6 --> d3
  d3 -->|"No — keep moving"| a6
  d3 -->|"Yes"| a7
  a7 --> done
  classDef proc fill:#e7f0fe,stroke:#2563eb,stroke-width:2px,color:#16357a
  classDef ent fill:#eceff3,stroke:#5b6b7f,stroke-width:2px,color:#2b3645
  classDef store fill:#fbf6e9,stroke:#b08423,stroke-width:2px,color:#6b4e12
  classDef ext fill:#e7f6f3,stroke:#0f766e,stroke-width:2px,color:#0f766e
  classDef term fill:#dcfce7,stroke:#16a34a,stroke-width:2px,color:#14532d
  classDef act fill:#e7f0fe,stroke:#2563eb,stroke-width:2px,color:#16357a
  classDef dec fill:#fef3c7,stroke:#d97706,stroke-width:2px,color:#7c4a03
