{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server/api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server/api/index.js" },
    { "src": "/assets/(.*)", "dest": "/client/assets/$1" },
    { "src": "/export360/(.*)", "dest": "/client/export360/$1" },
    { "src": "/android/(.*)", "dest": "/client/android/$1" },
    { "src": "/ios/(.*)", "dest": "/client/ios/$1" },
    { "src": "/windows/(.*)", "dest": "/client/windows/$1" },
    { "src": "/bg.png", "dest": "/client/bg.png" },
    { "src": "/logo.png", "dest": "/client/logo.png" },
    { "src": "/manifest.json", "dest": "/client/manifest.json" },
    { "src": "/favicon.ico", "dest": "/client/favicon.ico" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/client/index.html" }
]
}